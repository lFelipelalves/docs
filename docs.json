{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "LF Connect",
  "colors": {
    "primary": "#00B86B",
    "light": "#1FD980",
    "dark": "#00B86B"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Comece aqui",
            "pages": [
              "introduction",
              "essentials/authentication",
              "essentials/rate-limits",
              "essentials/webhooks"
            ]
          },
          {
            "group": "Funcionalidades",
            "pages": [
              "features/canais",
              "features/captain",
              "features/kanban",
              "features/campanhas",
              "features/automacoes"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Kanban",
            "pages": [
              "api-reference/kanban/funnels",
              "api-reference/kanban/items",
              "api-reference/kanban/movement",
              "api-reference/kanban/checklist",
              "api-reference/kanban/notes",
              "api-reference/kanban/bulk",
              "api-reference/kanban/automations"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/lf-light.svg",
    "dark": "/logo/lf-dark.svg",
    "href": "https://lfautomatiza.com"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0a"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "https://wa.me/5511936233536"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Acessar plataforma",
      "href": "https://chat.lfautomatiza.com"
    }
  },
  "search": {
    "prompt": "Buscar na documentação..."
  },
  "seo": {
    "metatags": {
      "og:site_name": "LF Connect — Documentação",
      "og:locale": "pt_BR"
    },
    "indexing": "navigable"
  },
  "footer": {
    "socials": {
      "website": "https://lfautomatiza.com",
      "linkedin": "https://www.linkedin.com/company/lfautomatiza"
    }
  },
  "fonts": {
    "heading": {
      "family": "Manrope",
      "weight": 700
    },
    "body": {
      "family": "Manrope"
    }
  }
}